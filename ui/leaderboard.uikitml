<style>
  .lb-panel {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 2;
    padding-bottom: 2;
    padding-left: 3;
    padding-right: 3;
    background-color: rgba(0, 8, 20, 0.92);
    border-color: #ffaa00;
    border-width: 0.12;
    border-radius: 1.5;
    gap: 0.6;
  }
  .lb-title {
    font-size: 2.5;
    color: #ffaa00;
    font-weight: bold;
  }
  .lb-row {
    display: flex;
